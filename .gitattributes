Manual/* linguist-documentation

# Golden test outputs must be byte-identical across all platforms.
tests/golden/** binary

# Line ending policy for source files
*.py text eol=lf
*.sh text eol=lf
*.csh text eol=lf
*.bash text eol=lf
*.ps1 text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.cpp text eol=lf
*.h   text eol=lf
*.c   text eol=lf
*.m   text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
Makefile text eol=lf
makefile text eol=lf

# Documentation and config
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# External C sources (vendored: Triangle, etc.)
external/triangle/src/*.c text eol=lf
external/triangle/src/*.h text eol=lf

# LaTeX documentation
*.tex text eol=lf
*.bib text eol=lf
*.bst text eol=lf
